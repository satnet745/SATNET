<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="Autofill,TextFields"
    style="@style/SatnetScreenScroll">

    <LinearLayout
        style="@style/SatnetScreenContent">

        <TextView
            style="@style/SatnetHeaderTitle"
            android:text="@string/satnet_verifier_title" />

        <TextView
            style="@style/SatnetHeaderSubtitle"
            android:text="@string/satnet_verifier_subtitle" />

        <TextView
            android:id="@+id/verifier_stage_badge_text"
            style="@style/SatnetHeaderBadge"
            android:text="@string/satnet_verifier_stage_placeholder" />

        <TextView
            android:id="@+id/verifier_runtime_status_text"
            style="@style/SatnetHeaderStatus"
            android:text="@string/satnet_verifier_runtime_placeholder" />

        <TextView
            android:id="@+id/verifier_summary_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#EEEEEE"
            android:minLines="8"
            android:padding="12dp"
            android:text="@string/satnet_verifier_summary_placeholder" />

        <LinearLayout
            android:id="@+id/verifier_trust_badge_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/verifier_manifest_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/satnet_badge_background"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/satnet_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/verifier_ledger_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/satnet_badge_background"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/satnet_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/verifier_rotation_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/satnet_badge_background"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/satnet_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/verifier_risk_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/satnet_badge_background"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/satnet_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/verifier_dispute_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/satnet_badge_background"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:textColor="@color/satnet_primary"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/verifier_policy_state_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:text="@string/satnet_verifier_policy_state_placeholder"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/verifier_audit_history_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/verifier_audit_history_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/satnet_verifier_audit_history_title"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/verifier_audit_history_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F5F5F5"
                android:minLines="4"
                android:padding="12dp"
                android:text="@string/satnet_verifier_audit_history_placeholder" />
        </LinearLayout>

        <EditText
            android:id="@+id/verifier_voucher_id_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:autofillHints=""
            android:hint="@string/satnet_verifier_voucher_id_hint"
            android:importantForAutofill="no"
            android:inputType="textCapCharacters"
            tools:ignore="Autofill,TextFields" />

        <EditText
            android:id="@+id/verifier_payload_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints=""
            android:gravity="top|start"
            android:hint="@string/satnet_verifier_payload_hint"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:minLines="4"
            tools:ignore="Autofill,TextFields" />

        <Button
            android:id="@+id/verifier_refresh_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/satnet_verifier_refresh_button" />

        <Button
            android:id="@+id/verifier_inspect_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/satnet_verifier_inspect_button" />

        <Button
            android:id="@+id/verifier_verify_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/satnet_verifier_verify_button" />

        <Button
            android:id="@+id/verifier_release_expired_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/satnet_verifier_release_button" />

    </LinearLayout>
</ScrollView>

