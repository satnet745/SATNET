<?xml version="1.0" encoding="utf-8"?>
<!--
 * Video Call Layout for Serval Mesh
 * Supports both audio-only and video calling modes
 -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="#000000" >

    <!-- Remote video surface (full screen) -->
    <SurfaceView
        android:id="@+id/remote_video_surface"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:visibility="gone" />

    <!-- Local video preview (picture-in-picture) -->
    <SurfaceView
        android:id="@+id/local_video_surface"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:visibility="gone" />

    <!-- Call information overlay -->
    <RelativeLayout
        android:id="@+id/call_info_overlay"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#80000000"
        android:padding="8dp" >

        <Chronometer
            android:id="@+id/call_time"
            style="@style/scall_status_details_right_time"
            android:layout_toStartOf="@+id/serval_id"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/serval_id"
            style="@style/scall_status_details_right_label"
            android:text="@string/app_name"
            android:textColor="#FFFFFF" />
    </RelativeLayout>

    <!-- Call action type (shown in center when no video) -->
    <TextView
        android:id="@+id/call_action_type"
        style="@style/scall_action_type"
        android:layout_below="@+id/call_info_overlay"
        android:text="@string/in_call"
        android:textColor="#FFFFFF" />

    <!-- Caller image (shown when no video) -->
    <ImageView
        android:id="@+id/caller_image"
        style="@style/scaller_image2"
        android:layout_below="@+id/call_action_type"
        android:layout_centerHorizontal="true"
        android:contentDescription="@string/caller_image"
        android:src="@drawable/ic_satnet_brand" />

    <!-- Caller name -->
    <TextView
        android:id="@+id/caller_name"
        style="@style/scall_action_type"
        android:layout_below="@+id/caller_image"
        android:layout_centerHorizontal="true"
        android:text="@string/contact_name"
        android:textColor="#FFFFFF" />

    <!-- Phone number display -->
    <TextView
        android:id="@+id/ph_no_display"
        style="@style/scall_no_display"
        android:layout_below="@+id/caller_name"
        android:layout_centerHorizontal="true"
        android:text="@string/phone_number"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/route_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/ph_no_display"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/route_indicator_none"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <!-- Video status indicator -->
    <TextView
        android:id="@+id/video_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/route_indicator"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/video_call"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Control buttons container -->
    <LinearLayout
        android:id="@+id/control_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:padding="8dp" >

        <!-- Video toggle button -->
        <ImageButton
            android:id="@+id/video_toggle_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/video_toggle_button"
            android:contentDescription="@string/toggle_video"
            android:scaleType="centerInside"
            android:visibility="visible" />

        <!-- End call button -->
        <Button
            android:id="@+id/cancel_call_button"
            style="@style/sph_controlButtons"
            android:layout_margin="8dp"
            android:background="@drawable/phone_endcall_button" />

        <!-- Camera switch button -->
        <ImageButton
            android:id="@+id/camera_switch_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/camera_switch_button"
            android:contentDescription="@string/switch_camera"
            android:scaleType="centerInside"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Incoming call buttons -->
    <Button
        android:id="@+id/answer_button_incoming"
        style="@style/scall_answer"
        android:layout_toStartOf="@+id/caller_image"
        android:layout_below="@+id/video_status" />

    <Button
        android:id="@+id/incoming_decline"
        style="@style/scall_decline"
        android:layout_alignBottom="@+id/answer_button_incoming"
        android:layout_toEndOf="@+id/caller_image" />

</RelativeLayout>

