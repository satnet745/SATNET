<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/satnet_background"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/satnet_card_surface"
            android:padding="16dp">

            <include layout="@layout/header_layout" />
        </RelativeLayout>

        <TextView
            android:id="@+id/bodySectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/main_body_title"
            android:textColor="@color/satnet_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/bodyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:id="@+id/mainStatusContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/satnet_card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/main_home_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/main_hub_intro"
                android:textColor="@color/satnet_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/main_home_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_horizontal"
                android:text="@string/main_hub_status_setup"
                android:textColor="@color/satnet_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/communicationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/satnet_card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/communicationSectionTitle"
                style="@style/smainTableRowText2"
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:text="@string/main_section_communication"
                android:textColor="@color/satnet_text_primary" />

            <TextView
                android:id="@+id/communicationSectionSummary"
                style="@style/smainTableRowText2"
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:text="@string/main_section_communication_summary"
                android:textColor="@color/satnet_text_secondary"
                android:textSize="13sp" />

            <TableLayout
                android:id="@+id/tableMain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:shrinkColumns="*"
                android:stretchColumns="*">

                <TableRow
                    android:id="@+id/tableRow1a"
                    style="@style/smainTableRow">

                    <ImageView
                        android:id="@+id/btncall"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/callLabel"
                        android:src="@drawable/ic_launcher_call" />

                    <ImageView
                        android:id="@+id/messageLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/messageLabel"
                        android:src="@drawable/ic_launcher_message" />

                    <ImageView
                        android:id="@+id/contactsLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/contactsLabel"
                        android:src="@drawable/ic_launcher_contacts" />
                </TableRow>

                <TableRow
                    android:id="@+id/tableRow1b"
                    style="@style/smainTableRow">

                    <TextView
                        android:id="@+id/callText"
                        style="@style/smainTableRowText"
                        android:text="@string/callLabel"
                        android:textColor="@color/satnet_text_primary" />

                    <TextView
                        android:id="@+id/messageText"
                        style="@style/smainTableRowText"
                        android:text="@string/messageLabel"
                        android:textColor="@color/satnet_text_primary" />

                    <TextView
                        android:id="@+id/contactsText"
                        style="@style/smainTableRowText"
                        android:text="@string/contactsLabel"
                        android:textColor="@color/satnet_text_primary" />
                </TableRow>

                <TableRow
                    android:id="@+id/tableRow2a"
                    style="@style/smainTableRow">

                    <ImageView
                        android:id="@+id/mapsLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/mapsLabel"
                        android:src="@drawable/ic_launcher_map" />

                    <ImageView
                        android:id="@+id/sharingLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/sharingLabel"
                        android:src="@drawable/ic_launcher_sharing" />

                    <ImageView
                        android:id="@+id/servalLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/servalLabel"
                        android:src="@drawable/ic_launcher_share_us" />
                </TableRow>

                <TableRow
                    android:id="@+id/tableRow2b"
                    style="@style/smainTableRow">

                    <TextView
                        android:id="@+id/mapsText"
                        style="@style/smainTableRowText"
                        android:text="@string/mapsLabel"
                        android:textColor="@color/satnet_text_primary" />

                    <TextView
                        android:id="@+id/sharingText"
                        style="@style/smainTableRowText"
                        android:text="@string/sharingLabel"
                        android:textColor="@color/satnet_text_primary" />

                    <TextView
                        android:id="@+id/wifiText"
                        style="@style/smainTableRowText"
                        android:text="@string/servalLabel"
                        android:textColor="@color/satnet_text_primary" />
                </TableRow>

                <TableRow
                    android:id="@+id/tableRow3a"
                    style="@style/smainTableRow">

                    <ImageView
                        android:id="@+id/settingsLabel"
                        style="@style/smainTableIcon"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/settingsLabel"
                        android:src="@drawable/ic_launcher_config" />

                    <ImageView
                        android:id="@+id/powerLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/powerLabel"
                        android:src="@drawable/ic_launcher_power" />

                    <ImageView
                        android:id="@+id/helpLabel"
                        style="@style/smainTableIcon"
                        android:contentDescription="@string/helpLabel"
                        android:src="@drawable/ic_launcher_help" />
                </TableRow>

                <TableRow
                    android:id="@+id/tableRow3b"
                    style="@style/smainTableRow">

                    <TextView
                        android:id="@+id/settingsText"
                        style="@style/smainTableRowText"
                        android:text="@string/settingsLabel"
                        android:textColor="@color/satnet_text_primary" />

                    <TextView
                        android:id="@+id/btntoggle"
                        style="@style/smainTableRowText"
                        android:text="@string/connectLabel"
                        android:textColor="@color/satnet_text_primary" />

                    <TextView
                        android:id="@+id/helpText"
                        style="@style/smainTableRowText"
                        android:text="@string/helpLabel"
                        android:textColor="@color/satnet_text_primary" />
                </TableRow>
            </TableLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/financeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/satnet_card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/financeSectionTitle"
                style="@style/smainTableRowText2"
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:text="@string/main_section_finance"
                android:textColor="@color/satnet_text_primary" />

            <TextView
                android:id="@+id/financeSectionSummary"
                style="@style/smainTableRowText2"
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:text="@string/main_section_finance_summary"
                android:textColor="@color/satnet_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/main_satnet_status"
                style="@style/smainTableRowText2"
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:text="@string/main_satnet_pending_summary"
                android:textColor="@color/satnet_text_secondary"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/satnetLabel"
                style="@style/smainTableIcon"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:contentDescription="@string/satnet_home_label"
                android:src="@drawable/ic_launcher_satnet" />

            <TextView
                android:id="@+id/satnetText"
                style="@style/smainTableRowText"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:gravity="center_horizontal"
                android:text="@string/satnet_home_label"
                android:textColor="@color/satnet_text_primary" />
        </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/footerSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/main_footer_section_title"
            android:textColor="@color/satnet_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/footerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/satnet_card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/footerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_footer_title"
                android:textColor="@color/satnet_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/footerSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_footer_summary"
                android:textColor="@color/satnet_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                android:id="@+id/phonelabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/PhoneDetails"
                android:textColor="@color/satnet_text_secondary" />

            <TextView
                android:id="@+id/mainphonenumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/satnet_text_primary" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
