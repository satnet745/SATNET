<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/SatnetScreenScroll">

    <LinearLayout
        style="@style/SatnetScreenContent">

        <TextView
            style="@style/SatnetHeaderTitle"
            android:text="@string/satnet_wallet_title"
            />

        <TextView
            style="@style/SatnetHeaderSubtitle"
            android:text="@string/satnet_wallet_subtitle"
            />

        <TextView
            android:id="@+id/wallet_stage_badge_text"
            style="@style/SatnetHeaderBadge"
            android:text="@string/satnet_wallet_stage_placeholder"
            />

        <TextView
            android:id="@+id/wallet_runtime_status_text"
            style="@style/SatnetHeaderStatus"
            android:text="@string/satnet_wallet_runtime_placeholder"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/satnet_card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/satnet_wallet_balance_label"
                android:textColor="@color/satnet_text_secondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/balance_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/satnet_wallet_balance_placeholder"
                android:textColor="@color/satnet_text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/satnet_wallet_address_label"
                android:textColor="@color/satnet_text_secondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/address_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/satnet_wallet_address_placeholder"
                android:textColor="@color/satnet_primary_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/satnet_wallet_address_hint"
                android:textColor="@color/satnet_text_secondary" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/satnet_wallet_actions_title"
            android:textColor="@color/satnet_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/satnet_wallet_actions_summary"
            android:textColor="@color/satnet_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/satnet_card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/role_action_summary_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/satnet_wallet_role_action_summary_default"
                android:textColor="@color/satnet_text_secondary" />

            <Button
                android:id="@+id/role_action_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/satnet_wallet_tools_button" />

            <Button
                android:id="@+id/hide_balance_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/satnet_wallet_hide_balance" />

            <Button
                android:id="@+id/backup_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/satnet_wallet_backup_button" />

            <Button
                android:id="@+id/share_address_chat_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/satnet_wallet_share_chat_button" />

            <Button
                android:id="@+id/send_bitcoin_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/satnet_wallet_send_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/passphrase_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/satnet_card_surface"
            android:padding="16dp"
            android:textColor="@color/satnet_text_primary"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/satnet_wallet_safety_title"
            android:textColor="@color/satnet_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/satnet_wallet_safety_summary"
            android:textColor="@color/satnet_text_secondary" />

        <Button
            android:id="@+id/panic_mode_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/satnet_danger_button_background"
            android:text="@string/satnet_wallet_panic_enable"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
