<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#FFE6ECF4" />
            <stroke android:width="1dp" android:color="#FFC2D0E1" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFE7EEF8" />
            <stroke android:width="1dp" android:color="@color/satnet_primary" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/satnet_surface" />
            <stroke android:width="1dp" android:color="@color/satnet_primary" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>

